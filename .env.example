# YouTube Data API v3 キー（Google Cloud Console で取得）
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gemini API キー（Google AI Studio で取得）
GEMINI_API_KEY=your_gemini_api_key_here

# Discord Webhook URL（サーバー設定 → 連携サービス → ウェブフック で取得）
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
DISCORD_IDEA_WEBHOOK_URL=your_discord_idea_webhook_url_here

# Discord Bot Token（Developer Portal → Bot → Token で取得）
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# :x: リアクション自動削除の対象チャンネルID
DISCORD_CLEANUP_CHANNEL_ID=your_channel_id_here
